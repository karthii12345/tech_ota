// ─────────────────────────────────────────────────────────────
//  HELPERS
// ─────────────────────────────────────────────────────────────
bool tcpSend(const char* msg) {
  if (!tcpClient.connected()) return false;
  size_t written = tcpClient.println(msg);
  if (written == 0) {
    tcpClient.stop();
    isAuthenticated = false;
    pendingReset = false;
    return false;
  }
  return true;
}

void setRelay(bool on) {
  digitalWrite(RELAY_PIN, on ? LOW  : HIGH);
  digitalWrite(LED_PIN,   on ? LOW  : HIGH);
}

bool isDeviceConfigured() {
  return (autoTimerDuration > 0)
      || dailySched.active
      || dailySched.configured
      || schedule.active
      || (deviceMode != 0);
}

void sendConfigReminderIfNeeded() {
  if (!isDeviceConfigured()) {
    tcpSend("REMINDER: Device not yet configured. Send -> auto:<mins>|daily:HH:MM,HH:MM");
  }
}

// ─────────────────────────────────────────────────────────────
//  INSTANT STATUS SYNC 
// ─────────────────────────────────────────────────────────────
void sendStatusUpdate() {
  if (!isAuthenticated) return;

  bool relayOn = (digitalRead(RELAY_PIN) == LOW);
  char modeBuf[12];
  modeName(deviceMode, modeBuf, sizeof(modeBuf));

  char buf[220];
  snprintf(buf, sizeof(buf),
           "SYNC: Mode=%s Relay=%s FlashWrites=(%lu/90k) "
           "AUTO=%s(%lumin) AutoRunning=%s "
           "DAILY=%s/conf=%s(%02d:%02d-%02d:%02d) DailyState=%d "
           "Configured=%s",
           modeBuf,
           relayOn ? "ON" : "OFF",
           flashWriteCount,
           (autoTimerDuration > 0 ? "SET" : "UNSET"),
           autoTimerDuration / 60000UL,
           (autoTimerRunning ? "YES" : "NO"),
           (dailySched.active     ? "ACTIVE"   : "INACTIVE"),
           (dailySched.configured ? "YES"      : "NO"),
           dailySched.startHour, dailySched.startMin,
           dailySched.endHour,   dailySched.endMin,
           dailySched.state,
           (isDeviceConfigured() ? "YES" : "NO"));
  tcpSend(buf);

  if (deviceMode == 3 && schedule.active) {
    char cbuf[110];
    snprintf(cbuf, sizeof(cbuf),
             "SYNC: CUSTOM Date=%02d/%02d/%04d Window=%02d:%02d-%02d:%02d Triggered=%s",
             schedule.day, schedule.month, schedule.year,
             schedule.startHour, schedule.startMin,
             schedule.endHour,   schedule.endMin,
             (schedule.hasTriggeredOn ? "YES" : "NO"));
    tcpSend(cbuf);
  }
}

void changeMode(int newMode) {
  if (deviceMode == newMode) return;
  if ((deviceMode == 2 || deviceMode == 4) && autoTimerRunning) {
    autoTimerRunning = false;
    setRelay(false);
  }
  autoInCooldown = false;
  waitForPirLow  = false; 
  char from[12], to[12], buf[64];
  modeName(deviceMode, from, sizeof(from));
  modeName(newMode,    to,   sizeof(to));
  deviceMode = newMode;
  snprintf(buf, sizeof(buf), "EVENT: [%s]->[%s]", from, to);
  Serial.println(buf);
  if (isAuthenticated) tcpSend(buf);
}

// ─────────────────────────────────────────────────────────────
//  PARSERS
// ─────────────────────────────────────────────────────────────
int parseAutoMinutes(const char* cmd) {
  const char* colon = strchr(cmd, ':');
  if (!colon) return 0;
  return atoi(colon + 1);
}

bool parseCustomCommand(const char* cmd, CustomSchedule& s) {
  const char* colon = strchr(cmd, ':');
  if (!colon) return false;
  char rest[96];
  strncpy(rest, colon + 1, sizeof(rest) - 1);
  rest[sizeof(rest) - 1] = '\0';

  for (char* p = rest; *p; ++p) if (*p == ',') *p = ';';
  char* trimmed = rest;
  while (*trimmed == ' ') trimmed++;

  char* s1 = strchr(trimmed, ';'); if (!s1) return false; *s1 = '\0';
  char* s2 = strchr(s1 + 1, ';'); if (!s2) return false; *s2 = '\0';
  char* datePart  = trimmed;
  char* startPart = s1 + 1;
  char* endPart   = s2 + 1;
  while (*startPart == ' ') startPart++;
  while (*endPart   == ' ') endPart++;

  char* d1 = strchr(datePart, '/'); if (!d1) return false;
  char* d2 = strchr(d1 + 1,   '/'); if (!d2) return false;
  *d1 = '\0'; *d2 = '\0';
  s.day   = atoi(datePart);
  s.month = atoi(d1 + 1);
  s.year  = atoi(d2 + 1);

  char* t1 = strchr(startPart, ':'); if (!t1) return false; *t1 = '\0';
  s.startHour = atoi(startPart);
  s.startMin  = atoi(t1 + 1);

  char* t2 = strchr(endPart, ':'); if (!t2) return false; *t2 = '\0';
  s.endHour = atoi(endPart);
  s.endMin  = atoi(t2 + 1);

  s.active         = true;
  s.hasTriggeredOn = false;
  return true;
}

bool parseDailyCommand(const char* cmd, DailySchedule& s) {
  const char* colon = strchr(cmd, ':');
  if (!colon) return false;
  char rest[64];
  strncpy(rest, colon + 1, sizeof(rest) - 1);
  rest[sizeof(rest) - 1] = '\0';

  char* trimmed = rest;
  while (*trimmed == ' ') trimmed++;

  char* comma = strchr(trimmed, ','); if (!comma) return false;
  *comma = '\0';
  char* startPart = trimmed;
  char* endPart   = comma + 1;
  while (*endPart == ' ') endPart++;

  char* t1 = strchr(startPart, ':'); if (!t1) return false; *t1 = '\0';
  s.startHour = atoi(startPart);
  s.startMin  = atoi(t1 + 1);

  char* t2 = strchr(endPart, ':'); if (!t2) return false; *t2 = '\0';
  s.endHour = atoi(endPart);
  s.endMin  = atoi(t2 + 1);

  s.active     = true;
  s.configured = true;
  s.state      = 0;
  return true;
}

// ─────────────────────────────────────────────────────────────
//  FLASH LOGIC 
// ─────────────────────────────────────────────────────────────
bool noteFlashWrite(const char* whatChanged) {
  if (flashWriteCount >= FLASH_DEAD_LIMIT) {
    Serial.println(F("CRITICAL: Flash write blocked! Max wear limit reached."));
    if (isAuthenticated) {
      tcpSend("CRITICAL: Flash write blocked to prevent hardware failure (90k limit). Setting applied to RAM only (volatile).");
    }
    return false;
  }

  flashWriteCount++;
  char buf[80];
  snprintf(buf, sizeof(buf), "EVENT: Flash write (%s) count=%lu/90k", whatChanged, flashWriteCount);
  Serial.println(buf);
  if (isAuthenticated) tcpSend(buf);

  if (flashWriteCount == FLASH_ALERT_50) {
    if (isAuthenticated) tcpSend("ALERT: Flash memory wear has reached ~50% (45000/90000)!");
  }
  if (flashWriteCount == FLASH_HARD_LIMIT) {
    if (isAuthenticated) tcpSend("ALERT: Flash wear near limit (85000/90000) — config writes still allowed but consider reducing change frequency.");
  }
  return true;
}

void loadToken() {
  strncpy(activeToken, BUILT_IN_TOKEN, sizeof(activeToken) - 1);
  activeToken[sizeof(activeToken) - 1] = '\0';

  File f = LittleFS.open("/token.txt", "r");
  if (f) {
    String t = f.readStringUntil('\n'); t.trim();
    if (t.length() > 0 && t.length() < sizeof(activeToken)) {
      strncpy(activeToken, t.c_str(), sizeof(activeToken) - 1);
      activeToken[sizeof(activeToken) - 1] = '\0';
    }
    String cStr = f.readStringUntil('\n'); cStr.trim();
    if (cStr.length() > 0) {
      unsigned long c = (unsigned long)cStr.toInt();
      if (c > flashWriteCount) flashWriteCount = c;
    }
    f.close();
  }

  File reg = LittleFS.open("/registered.txt", "r");
  if (reg) {
    isRegistered = true;
    reg.readStringUntil('\n');
    String cStr = reg.readStringUntil('\n'); cStr.trim();
    if (cStr.length() > 0) {
      unsigned long c = (unsigned long)cStr.toInt();
      if (c > flashWriteCount) flashWriteCount = c;
    }
    reg.close();
    Serial.println(F("Flash: Device is marked as Verified & Registered."));
  }
}

void unifyFlashCount() {
  File f = LittleFS.open("/token.txt", "r");
  if (!f) return;
  String tok = f.readStringUntil('\n'); tok.trim();
  f.close();
  if (tok.length() == 0) return;

  File fw = LittleFS.open("/token.txt", "w");
  if (fw) {
    fw.println(tok);
    fw.println(flashWriteCount);
    fw.close();
  }
}

void saveToken(const char* newToken) {
  if (!noteFlashWrite("token")) {
    strncpy(activeToken, newToken, sizeof(activeToken) - 1);
    activeToken[sizeof(activeToken) - 1] = '\0';
    return;
  }

  File f = LittleFS.open("/token.txt", "w");
  if (f) {
    f.println(newToken);
    f.println(flashWriteCount);
    f.close();
    strncpy(activeToken, newToken, sizeof(activeToken) - 1);
    activeToken[sizeof(activeToken) - 1] = '\0';
  } else {
    Serial.println(F("ERR: Failed to open /token.txt for write"));
  }
}

bool loadCredentials(String& ssid, String& pass) {
  File f = LittleFS.open("/cfg.txt", "r");
  if (!f) return false;
  ssid = f.readStringUntil('\n'); ssid.trim();
  pass = f.readStringUntil('\n'); pass.trim();
  String cStr = f.readStringUntil('\n'); cStr.trim();
  if (cStr.length() > 0) {
    unsigned long c = (unsigned long)cStr.toInt();
    if (c > flashWriteCount) flashWriteCount = c;
  }
  f.close();
  return (ssid.length() > 0);
}

void saveCredentials(const String& ssid, const String& pass) {
  String existSSID, existPASS;
  File f_check = LittleFS.open("/cfg.txt", "r");
  if (f_check) {
    existSSID = f_check.readStringUntil('\n'); existSSID.trim();
    existPASS = f_check.readStringUntil('\n'); existPASS.trim();
    f_check.close();
  }

  if (existSSID == ssid && existPASS == pass) {
    Serial.println(F("Credentials identical. Skipping flash write."));
    return;
  }

  if (!noteFlashWrite("wifi-credentials")) return;

  File f = LittleFS.open("/cfg.txt", "w");
  if (f) {
    f.println(ssid);
    f.println(pass);
    f.println(flashWriteCount);
    f.close();
    Serial.println(F("New credentials saved to flash."));
  }
}

bool writeStateFile() {
  File f = LittleFS.open("/state.txt", "w");
  if (!f) return false;
  f.println(deviceMode);
  f.println(autoTimerDuration);
  f.println(schedule.year);
  f.println(schedule.month);
  f.println(schedule.day);
  f.println(schedule.startHour);
  f.println(schedule.startMin);
  f.println(schedule.endHour);
  f.println(schedule.endMin);
  f.println(schedule.active ? 1 : 0);
  f.println(dailySched.startHour);
  f.println(dailySched.startMin);
  f.println(dailySched.endHour);
  f.println(dailySched.endMin);
  f.println(dailySched.active     ? 1 : 0);
  f.println(dailySched.configured ? 1 : 0);
  f.println(flashWriteCount);
  f.close();
  return true;
}

void saveState(const char* reason = "state") {
  if (!noteFlashWrite(reason)) return;
  writeStateFile();
}

void loadState() {
  File f = LittleFS.open("/state.txt", "r");
  if (!f) return;

  deviceMode           = f.readStringUntil('\n').toInt();
  autoTimerDuration    = (unsigned long)f.readStringUntil('\n').toInt();
  schedule.year        = f.readStringUntil('\n').toInt();
  schedule.month       = f.readStringUntil('\n').toInt();
  schedule.day         = f.readStringUntil('\n').toInt();
  schedule.startHour   = f.readStringUntil('\n').toInt();
  schedule.startMin    = f.readStringUntil('\n').toInt();
  schedule.endHour     = f.readStringUntil('\n').toInt();
  schedule.endMin      = f.readStringUntil('\n').toInt();
  schedule.active      = f.readStringUntil('\n').toInt() == 1;
  dailySched.startHour = f.readStringUntil('\n').toInt();
  dailySched.startMin  = f.readStringUntil('\n').toInt();
  dailySched.endHour   = f.readStringUntil('\n').toInt();
  dailySched.endMin    = f.readStringUntil('\n').toInt();
  dailySched.active    = f.readStringUntil('\n').toInt() == 1;

  String cfgLine = f.readStringUntil('\n'); cfgLine.trim();
  if (cfgLine.length() > 0) {
    dailySched.configured = cfgLine.toInt() == 1;
  } else {
    dailySched.configured = dailySched.active
      || (dailySched.startHour + dailySched.startMin
          + dailySched.endHour  + dailySched.endMin) > 0;
  }

  String cStr = f.readStringUntil('\n'); cStr.trim();
  if (cStr.length() > 0) {
    unsigned long c = (unsigned long)cStr.toInt();
    if (c > flashWriteCount) flashWriteCount = c;
  }
  f.close();

  if (deviceMode == 1)                  deviceMode = 0;
  if (deviceMode < 0 || deviceMode > 4) deviceMode = 0;

  schedule.hasTriggeredOn = false;
  autoTimerRunning        = false;
  autoInCooldown          = false;
  dailySched.state        = 0;
}

