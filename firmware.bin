  MODE_MANUAL, MODE_UNUSED, MODE_AUTOT, MODE_CUSTOM, MODE_DAILY
};

void modeName(int mode, char* out, size_t outSz) {
  strncpy_P(out, (PGM_P)pgm_read_ptr(&MODE_NAMES[mode]), outSz - 1);
  out[outSz - 1] = '\0';
}

