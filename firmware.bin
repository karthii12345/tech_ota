  int  year, month, day;
  int  startHour, startMin;
  int  endHour,   endMin;
  bool active;
  bool hasTriggeredOn;
};
CustomSchedule schedule = {0, 0, 0, 0, 0, 0, 0, false, false};

struct DailySchedule {
  int  startHour, startMin;
  int  endHour,   endMin;
  bool active;
  bool configured;
  int  state;      // 0=idle  1=window-ON  2=skipped-until-tomorrow
};
DailySchedule dailySched = {0, 0, 0, 0, false, false, 0};

