const char index_html[] PROGMEM = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Device Setup</title>
  <style>
    body{font-family:Arial,sans-serif;text-align:center;margin-top:40px;background:#f4f4f9}
    .box{background:#fff;padding:20px;border-radius:8px;box-shadow:0 0 10px rgba(0,0,0,.1);display:inline-block;width:90%;max-width:350px}
    select,button{margin:8px auto;padding:10px;width:90%;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;display:block;font-size:16px}
    .ic{width:90%;margin:8px auto;text-align:left}
    #ms{display:none;width:100%;padding:10px;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;margin-bottom:8px;font-size:16px}
    .ic input[type=password],.ic input[type=text]{width:100%;padding:10px;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;font-size:16px}
    .sp{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:14px;cursor:pointer;color:#444}
    .sp input{width:auto;margin:0}
    .pr{background:#0056b3;color:#fff;border:none;cursor:pointer;margin-top:15px}
    .pr:hover{background:#004494}
    #sb{background:#6c757d;color:#fff;border:none;cursor:pointer;margin-bottom:15px}
    #sb:hover{background:#565e64}
    #st{margin-top:16px;font-weight:700;padding:10px;border-radius:4px;display:none;width:90%;margin-left:auto;margin-right:auto;box-sizing:border-box}
    .wait{display:block!important;background:#fff3cd;color:#856404}
    .ok{display:block!important;background:#d4edda;color:#155724}
    .fail{display:block!important;background:#f8d7da;color:#721c24}
  </style>
</head>
<body>
<div class="box">
  <h2>Device Setup</h2>
  <button id="sb" onclick="doScan()">Scan Networks</button>
  <select id="sel" onchange="togM()">
    <option value="">-- select network --</option>
    <option value="MANUAL">++ Enter SSID Manually ++</option>
  </select>
  <div class="ic">
    <input type="text" id="ms" placeholder="Hidden SSID name">
    <input type="password" id="pw" placeholder="Password (min 8 chars)">
    <label class="sp">
      <input type="checkbox" onchange="document.getElementById('pw').type=this.checked?'text':'password'">
      Show password
    </label>
  </div>
  <button id="cb" class="pr" onclick="doSave()">Save &amp; Connect</button>
  <div id="st"></div>
</div>
<script>
let pt;
window.onload=doScan;
function togM(){document.getElementById('ms').style.display=document.getElementById('sel').value==='MANUAL'?'block':'none';}
function ss(c,m){let e=document.getElementById('st');e.className=c;e.innerText=m;}
function unlock(){document.getElementById('cb').disabled=false;document.getElementById('sb').disabled=false;}
function doScan(){
  document.getElementById('sel').innerHTML='<option>Scanning...</option>';
  document.getElementById('ms').style.display='none';
  fetch('/scan');
  let t=setInterval(()=>{
    fetch('/scan-results').then(r=>r.json()).then(d=>{
      if(d.status==='done'){
        clearInterval(t);
        let s=document.getElementById('sel');
        s.innerHTML='<option value="">-- select network --</option>';
        d.networks.forEach(n=>{s.innerHTML+=`<option value="${n.ssid}">${n.ssid} (${n.rssi} dBm)</option>`;});
        s.innerHTML+='<option value="MANUAL">++ Enter SSID Manually ++</option>';
      }
    }).catch(()=>clearInterval(t));
  },2000);
}
function doSave(){
  let sel=document.getElementById('sel').value;
  let ssid=sel==='MANUAL'?document.getElementById('ms').value.trim():sel;
  let pass=document.getElementById('pw').value;
  if(!sel||sel===''){ss('fail','Select a network first.');return;}
  if(sel==='MANUAL'&&ssid===''){ss('fail','Type the hidden SSID.');return;}
  if(pass===''){ss('fail','Password cannot be empty.');return;}
  if(pass.length<8){ss('fail','Password must be at least 8 characters.');return;}
  document.getElementById('cb').disabled=true;
  document.getElementById('sb').disabled=true;
  clearInterval(pt);
  ss('wait','Connecting... please wait up to 20s');
  fetch('/save?ssid='+encodeURIComponent(ssid)+'&pass='+encodeURIComponent(pass))
    .then(r=>{
      if(r.ok){pt=setInterval(poll,2000);}
      else{r.text().then(t=>{ss('fail',t);unlock();});}
    }).catch(()=>{pt=setInterval(poll,2000);});
}
function poll(){
  fetch('/status').then(r=>r.json()).then(d=>{
    if(d.s==='ONLINE'){
      clearInterval(pt);let sec=8;
      ss('ok','Connected! Portal closes in '+sec+'s...');
      let ct=setInterval(()=>{sec--;if(sec>0)ss('ok','Connected! Portal closes in '+sec+'s...');else{clearInterval(ct);ss('ok','Portal closed. Device running.');}},1000);
    }
    else if(d.s==='FAILED'){
      clearInterval(pt);
      ss('fail','Wrong password or out of range. Check your password and try again.');
      unlock();
    }
    else{ss('wait','Connecting to router...');}
  }).catch(()=>{});
}
</script>
</body>
</html>
)rawliteral";

// ─────────────────────────────────────────────────────────────
//  START SETUP PORTAL
// ─────────────────────────────────────────────────────────────
void startSetupPortal() {
  inSetupMode        = true;
  setupStartTime     = millis();
  portalState        = 0;
  triggerConnection  = false;
  tempSSID = "";
  tempPASS = "";

  String mac = WiFi.macAddress();
  mac.replace(":", "");
  snprintf(global_AP_Name, sizeof(global_AP_Name), "Techorc_%s", mac.c_str());

  IPAddress local_IP(192, 168, 4, 1);
  IPAddress gateway(192, 168, 4, 1);
  IPAddress subnet(255, 255, 255, 0);

  WiFi.mode(WIFI_AP_STA);
  WiFi.softAPConfig(local_IP, gateway, subnet);
  WiFi.softAP(global_AP_Name, AP_PASS);
  dnsServer.start(DNS_PORT, "*", local_IP);

  server.on("/", HTTP_GET, [](AsyncWebServerRequest* r) {
    r->send_P(200, "text/html", index_html);
  });
  server.on("/scan", HTTP_GET, [](AsyncWebServerRequest* r) {
    if (WiFi.scanComplete() != WIFI_SCAN_RUNNING) WiFi.scanNetworks(true);
    r->send(200);
  });
  server.on("/scan-results", HTTP_GET, [](AsyncWebServerRequest* r) {
    int n = WiFi.scanComplete();
    if (n == WIFI_SCAN_RUNNING) {
      r->send(200, "application/json", F("{\"status\":\"scanning\"}"));
    } else if (n < 0) {
      r->send(200, "application/json", F("{\"status\":\"failed\"}"));
    } else {
      String json;
      json.reserve(512);
      json = F("{\"status\":\"done\",\"networks\":[");
      for (int i = 0; i < n; ++i) {
        if (i > 0) json += ',';
        json += F("{\"ssid\":\"");
        json += WiFi.SSID(i);
        json += F("\",\"rssi\":");
        json += WiFi.RSSI(i);
        json += '}';
      }
      json += F("]}");
      WiFi.scanDelete();
      r->send(200, "application/json", json);
    }
  });
  server.on("/save", HTTP_GET, [](AsyncWebServerRequest* r) {
    if (!r->hasParam("ssid") || !r->hasParam("pass")) {
      r->send(400, "text/plain", F("Missing parameters")); return;
    }
    tempSSID = r->getParam("ssid")->value(); tempSSID.trim();
    tempPASS = r->getParam("pass")->value();
    if (tempSSID.length() == 0) { r->send(400, "text/plain", F("SSID is empty"));             return; }
    if (tempPASS.length() == 0) { r->send(400, "text/plain", F("Password is empty"));         return; }
    if (tempPASS.length() < 8)  { r->send(400, "text/plain", F("Password must be 8+ chars")); return; }
    triggerConnection = true;
    r->send(200, "text/plain", F("OK"));
  });
  server.on("/status", HTTP_GET, [](AsyncWebServerRequest* r) {
    const char* s;
    switch (portalState) {
      case 1:  s = "{\"s\":\"PENDING\"}"; break;
      case 4:  s = "{\"s\":\"ONLINE\"}";  break;
      case 6:  s = "{\"s\":\"FAILED\"}";  break;
      default: s = "{\"s\":\"IDLE\"}";    break;
    }
    r->send(200, "application/json", s);
  });
  server.onNotFound([](AsyncWebServerRequest* r) { r->redirect("/"); });
  server.begin();
  Serial.print(F("Portal AP: ")); Serial.println(global_AP_Name);
}

// ─────────────────────────────────────────────────────────────
//  SETUP
// ─────────────────────────────────────────────────────────────
void setup() {
  ESP.wdtEnable(8000);

  pinMode(LED_PIN,   OUTPUT);
  digitalWrite(RELAY_PIN, HIGH); 
  digitalWrite(LED_PIN,   HIGH); 
  pinMode(PIR_PIN,   INPUT);
  pinMode(RELAY_PIN, OUTPUT);

  Serial.begin(115200, SERIAL_8N1, SERIAL_TX_ONLY);
  delay(500);

  Serial.print(F("Reset reason: "));
  Serial.println(ESP.getResetReason());

  rst_info* rinfo = ESP.getResetInfoPtr();
  if (rinfo->reason == REASON_WDT_RST
      || rinfo->reason == REASON_EXCEPTION_RST
      || rinfo->reason == REASON_SOFT_WDT_RST) {
    Serial.printf("Crash detail -> reason:%d exccause:%d epc1:0x%08x epc2:0x%08x epc3:0x%08x excvaddr:0x%08x depc:0x%08x\n",
                   rinfo->reason, rinfo->exccause,
                   rinfo->epc1, rinfo->epc2, rinfo->epc3,
                   rinfo->excvaddr, rinfo->depc);
  }

  // Print MAC Address clearly for OTA targeting
  String myMac = WiFi.macAddress();
  myMac.replace(":", "");
  Serial.print(F("Device Unique ID (MAC for OTA): "));
  Serial.println(myMac);
  Serial.printf("Firmware Version: v%s\n", CURRENT_VERSION);

  lastPirState = digitalRead(PIR_PIN);

  // ── ROBUST LittleFS MOUNTING (NEVER FORMAT) ──
  bool fsMounted = false;
  for (int i = 0; i < 10; i++) {
    if (LittleFS.begin()) {
      fsMounted = true;
      break; 
    }
    Serial.println(F("LittleFS mount failed due to power dip. Waiting 1s..."));
    delay(1000); 
    ESP.wdtFeed(); 
  }

  if (!fsMounted) {
    Serial.println(F("CRITICAL: Flash memory not responding. Rebooting to try again..."));
    delay(1000);
    ESP.restart(); 
  }

  loadToken();
  loadState();
  unifyFlashCount();

  Serial.printf("Flash: Lifetime Write Count loaded (%lu/90k)\n", flashWriteCount);

  WiFi.persistent(false);
  WiFi.setAutoReconnect(true);
  WiFi.setSleepMode(WIFI_NONE_SLEEP);

  String savedSSID, savedPASS;
  bool hasCredentials = loadCredentials(savedSSID, savedPASS);

  if (hasCredentials) {
    Serial.print(F("Saved SSID found: ")); Serial.println(savedSSID);
    
    WiFi.mode(WIFI_STA);
    WiFi.begin(savedSSID.c_str(), savedPASS.c_str());

    Serial.println(F("Waiting up to 15s for WiFi connection..."));
    unsigned long bootStart = millis();
    while (millis() - bootStart < 15000UL) {
      ESP.wdtFeed();
      if (WiFi.status() == WL_CONNECTED) {
        Serial.println(F("WiFi connected. Starting NTP..."));
        configTime(19800, 0, "pool.ntp.org", "time.nist.gov");
        lastNtpSync = millis();
        break;
      }
      delay(500);
    }
    
    if (WiFi.status() != WL_CONNECTED) {
      Serial.println(F("Boot connect timed out. Device will retry continuously in background."));
    }
  } else {
    Serial.println(F("No credentials — starting portal."));
    startSetupPortal();
  }

  lastLoopExecution = millis();
}

// ─────────────────────────────────────────────────────────────
//  LOOP
// ─────────────────────────────────────────────────────────────
void loop() {
  ESP.wdtFeed();

  // ── SOFTWARE WATCHDOG ──
  if (millis() - lastLoopExecution > MAX_LOOP_TIME) {
    Serial.println(F("SOFT-WDT: Logic frozen > 2 min. Restarting."));
    ESP.restart();
  }
  lastLoopExecution = millis();

  // ============================================================
  //  SECTION 1 — SETUP PORTAL STATE MACHINE
  // ============================================================
  if (inSetupMode) {
    dnsServer.processNextRequest();

    if (triggerConnection) {
      triggerConnection   = false;
      portalState         = 0;
      WiFi.disconnect(false);
      delay(200);
      WiFi.mode(WIFI_AP_STA);
      delay(100);
      WiFi.begin(tempSSID.c_str(), tempPASS.c_str());
      portalState         = 1;
      connectionStartTime = millis();
    }

    if (portalState == 1) {
      int ws = WiFi.status();
      if (ws == WL_CONNECTED) {
        saveCredentials(tempSSID, tempPASS);
        configTime(19800, 0, "pool.ntp.org", "time.nist.gov");
        lastNtpSync            = millis();
        portalState           = 4;
        connectionGraceActive = true;
        connectionSuccessTime = millis();
      } else if (
        ws == WL_CONNECT_FAILED
        || ws == WL_WRONG_PASSWORD
        || ws == WL_NO_SSID_AVAIL
        || millis() - connectionStartTime > 15000UL
      ) {
        portalState = 6;
        WiFi.disconnect(false);
        tempSSID = "";
        tempPASS = "";
      }
    }

    if (connectionGraceActive
        && millis() - connectionSuccessTime > GRACE_PERIOD_MS) {
      server.end();
      dnsServer.stop();
      WiFi.mode(WIFI_STA);
      connectionGraceActive = false;
      inSetupMode           = false;
      Serial.println(F("Portal closed. Entering normal operation."));
    }

    if (!connectionGraceActive
        && portalState != 1
        && millis() - setupStartTime > SETUP_TIMEOUT_MS) {
      Serial.println(F("Portal timeout — restarting."));
      ESP.restart();
    }
    return;
  }

  // ============================================================
  //  SECTION 1b — WIFI HEALTH
  // ============================================================
  if (millis() - lastWifiCheck > WIFI_CHECK_MS) {
    lastWifiCheck = millis();
    if (WiFi.status() != WL_CONNECTED) {
      wifiDropCount++;
    } else {
      if (wifiDropCount > 0) {
        Serial.println(F("WiFi link restored."));
        configTime(19800, 0, "pool.ntp.org", "time.nist.gov");
        lastNtpSync = millis();
      }
      wifiDropCount = 0;
    }
  }

  // ── PERIODIC NTP RESYNC ──
  if (WiFi.status() == WL_CONNECTED
      && millis() - lastNtpSync > NTP_RESYNC_MS) {
    lastNtpSync = millis();
    configTime(19800, 0, "pool.ntp.org", "time.nist.gov");
    Serial.println(F("NTP: periodic resync triggered."));
  }

  if (WiFi.status() != WL_CONNECTED) return; 

  // ============================================================
  //  SECTION 2 — TCP SERVER CONNECTION
  // ============================================================
  if (!tcpClient.connected()) {
    if (isAuthenticated) Serial.println(F("Server disconnected."));
    isAuthenticated = false;
    pendingReset    = false;
    bufIdx          = 0;

    unsigned long now = millis();
    if (now - lastReconnectAttempt >= reconnectBackoff) {
      lastReconnectAttempt = now;
      tcpClient.stop(); 

      Serial.printf("Connecting to TCP Server %s:%d...\n", serverIP, serverPort);
      if (tcpClient.connect(serverIP, serverPort)) {
        tcpClient.setNoDelay(true);
        Serial.println(F("ONLINE"));
        reconnectBackoff = RECONNECT_MIN; 

        if (isRegistered) {
          isAuthenticated = true;
          tcpClient.println(F("ONLINE: Auto-Authenticated (Verified in Flash)."));
          sendStatusUpdate();                
          if (!isDeviceConfigured()) {
            tcpClient.println(F("REMINDER: Device not yet configured. Send -> auto:<mins>|daily:HH:MM,HH:MM"));
          }
        } else {
          tcpClient.println(F("ONLINE: Unregistered. Please send your token to verify and unlock."));
        }
      } else {
        reconnectBackoff = min(reconnectBackoff * 2, RECONNECT_MAX);
        Serial.printf("TCP connect failed. Next retry in %lums.\n", reconnectBackoff);
      }
    }
    goto run_modes;
  }

  // ============================================================
  //  SECTION 3 — COMMAND HANDLING
  // ============================================================
  while (tcpClient.available() > 0) {
    char c = tcpClient.read();

    if (c == '\n') {
      lineBuf[bufIdx] = '\0';
      int len = bufIdx;
      bufIdx = 0; 

      while (len > 0 && (lineBuf[len - 1] == '\r' || lineBuf[len - 1] == ' ')) {
        lineBuf[--len] = '\0';
      }
      char* trimmedLine = lineBuf;
      while (*trimmedLine == ' ') trimmedLine++;

      if (strlen(trimmedLine) == 0) continue; 

      strncpy(upperBuf, trimmedLine, LINE_BUF_SZ - 1);
      upperBuf[LINE_BUF_SZ - 1] = '\0';
      for (char* p = upperBuf; *p; ++p) *p = toupper(*p);

      // ────────────────────────────────────────────────────────
      //  SMART OTA UPDATE LOGIC (MAC Specific + Version Check)
      // ────────────────────────────────────────────────────────
      String myMac = WiFi.macAddress();
      myMac.replace(":", ""); 
      String targetUpdateCmd = myMac + ":UPDATE";
      
      if (strcmp(upperBuf, targetUpdateCmd.c_str()) == 0) {
        char msgBuf[128];
        snprintf(msgBuf, sizeof(msgBuf), "ACK: Target match (%s). Checking GitHub for firmware...", myMac.c_str());
        tcpSend(msgBuf);
        
        WiFiClientSecure secureClient;
        secureClient.setInsecure(); // Trust GitHub HTTPS
        HTTPClient http;
        
        // --- EDIT THIS LINE: CHANGE 'YourUsername/techorc-iot-updates' TO YOUR DETAILS ---
        http.begin(secureClient, "https://raw.githubusercontent.com/karthii12345/tech_ota/refs/heads/main/version.txt");
        int httpCode = http.GET();
        
        if (httpCode == HTTP_CODE_OK) {
          String latestVersion = http.getString();
          latestVersion.trim();
          
          char buf[128];
          // Smart Version Check: Protects against redundant downloads
          if (latestVersion == String(CURRENT_VERSION)) {
            snprintf(buf, sizeof(buf), "UPDATE_READY: Device is already up to date (v%s). No update needed.", CURRENT_VERSION);
            tcpSend(buf);
            pendingOtaUpdate = false; 
          } else {
            snprintf(buf, sizeof(buf), "UPDATE_READY: Current v%s -> New v%s. Send YES to install.", CURRENT_VERSION, latestVersion.c_str());
            tcpSend(buf);
            pendingOtaUpdate = true; // Arm the YES command
          }
        } else {
          tcpSend("ERR: Failed to reach GitHub or version file not found.");
        }
        http.end();
        continue;
      }

      // Execute the OTA Update upon receiving YES
      if (pendingOtaUpdate && strcmp(upperBuf, "YES") == 0) {
        pendingOtaUpdate = false;
        
        // SAFETY FIRST: Pause all timers and shut OFF relay before CPU freezes
        changeMode(0);
        schedule.active   = false;
        dailySched.active = false;
        autoTimerRunning  = false;
        manualOverrideON  = false;
        setRelay(false);
        
        tcpSend("ACK: Starting firmware download... Device will be unresponsive for 30 seconds.");
        tcpSend("STATUS: If successful, connection will drop and device will reboot.");
        delay(500); 

        WiFiClientSecure secureClient;
        secureClient.setInsecure(); 
        
        // --- EDIT THIS LINE: CHANGE 'YourUsername/techorc-iot-updates' TO YOUR DETAILS ---
        t_httpUpdate_return ret = ESPhttpUpdate.update(secureClient, "https://raw.githubusercontent.com/karthii12345/tech_ota/refs/heads/main/firmware.bin");

        switch (ret) {
          case HTTP_UPDATE_FAILED:
            char errBuf[128];
            snprintf(errBuf, sizeof(errBuf), "ERR: Update Failed. HTTP Error: %s. Resuming normal operation.", ESPhttpUpdate.getLastErrorString().c_str());
            tcpSend(errBuf);
            break;
            
          case HTTP_UPDATE_NO_UPDATES:
            tcpSend("ERR: No updates found. Resuming normal operation.");
            break;
            
          case HTTP_UPDATE_OK:
            // Never reached (reboots instantly on success)
            break;
        }
        continue;
      }

      // Clear pending update if they type something other than YES
      if (pendingOtaUpdate) {
        pendingOtaUpdate = false;
        tcpSend("ACK: Update cancelled. Normal command processing resumed.");
      }

      // ────────────────────────────────────────────────────────
      //  TWO-STEP RESET CONFIRMATION
      // ────────────────────────────────────────────────────────
      if (pendingReset) {
        if (strcmp(trimmedLine, activeToken) == 0) {
          tcpSend("ACK: Token Verified. FULL RESET in progress. Erasing data and restarting...");
          delay(100);
          LittleFS.remove("/cfg.txt");
          LittleFS.remove("/token.txt");
          LittleFS.remove("/registered.txt");
          deviceMode        = 0;
          autoTimerDuration = 0;
          dailySched.active = false;
          dailySched.configured = false;
          schedule.active   = false;
          writeStateFile();
          WiFi.disconnect(true);
          delay(500);
          ESP.restart();
        } else {
          pendingReset = false;
          tcpSend("ERR: Invalid Token. Reset aborted. System returned to normal operation.");
        }
        continue; 
      }

      // ────────────────────────────────────────────────────────
      //  AUTHENTICATION HANDSHAKE
      // ────────────────────────────────────────────────────────
      if (!isAuthenticated) {
        if (strcmp(trimmedLine, activeToken) == 0) {
          isAuthenticated = true;
          if (!isRegistered) {
            isRegistered = true;
            noteFlashWrite("registration");
            File f = LittleFS.open("/registered.txt", "w");
            if (f) { f.println("1"); f.println(flashWriteCount); f.close(); }
            tcpSend("ACK: Token Verified. Device registered to Flash.");
          } else {
            tcpSend("ACK: Authenticated successfully.");
          }
          sendStatusUpdate();                
          sendConfigReminderIfNeeded();
        } else {
          tcpSend("ERR: Invalid Token. Send only the token value (no prefix).");
          tcpClient.stop();
        }
        continue; 
      }

      // ────────────────────────────────────────────────────────
      //  FLASH COMMANDS
      // ────────────────────────────────────────────────────────
      char ackBuf[128];

      // 1. COMBINED CONFIG  auto:<mins>|daily:HH:MM,HH:MM
      char* pipe = strchr(upperBuf, '|');
      if (pipe && strncmp(upperBuf, "AUTO:", 5) == 0) {
        size_t pipeIdx = (size_t)(pipe - upperBuf);
        char autoPart[64], dailyPart[64];
        strncpy(autoPart, trimmedLine, min(pipeIdx, sizeof(autoPart) - 1));
        autoPart[min(pipeIdx, sizeof(autoPart) - 1)] = '\0';
        strncpy(dailyPart, trimmedLine + pipeIdx + 1, sizeof(dailyPart) - 1);
        dailyPart[sizeof(dailyPart) - 1] = '\0';

        int autoMins = parseAutoMinutes(autoPart);
        DailySchedule ns = {0, 0, 0, 0, false, false, 0};

        char dailyUpper[64];
        strncpy(dailyUpper, dailyPart, sizeof(dailyUpper) - 1);
        dailyUpper[sizeof(dailyUpper) - 1] = '\0';
        for (char* p = dailyUpper; *p; ++p) *p = toupper(*p);

        if (strncmp(dailyUpper, "DAILY:", 6) != 0 || !parseDailyCommand(dailyPart, ns)) {
          tcpSend("ERR: Bad DAILY format. Use auto:<mins>|daily:HH:MM,HH:MM");
        } else {
          bool dailyIsSkip = (ns.startHour == 0 && ns.startMin == 0
                              && ns.endHour  == 0 && ns.endMin  == 0);
          if (!dailyIsSkip
              && (ns.startHour * 60 + ns.startMin) == (ns.endHour * 60 + ns.endMin)) {
            tcpSend("ERR: DAILY start and end times must differ.");
          } else {
            autoTimerDuration = (unsigned long)autoMins * 60000UL;
            dailySched        = ns;

            if (!dailyIsSkip) {
              deviceMode          = 4;
              schedule.active     = false;
              autoTimerRunning    = false;
              dailySched.active   = true;
              dailySched.configured = true;
              dailySched.state    = 0;
              setRelay(false);
            } else if (autoMins > 0) {
              deviceMode          = 2;
              schedule.active     = false;
              dailySched.active   = false;
              autoTimerRunning    = false;
              setRelay(false);
              lastPirState        = digitalRead(PIR_PIN);
              lastPirChangeTime   = millis();
            } else {
              deviceMode          = 0;
              schedule.active     = false;
              dailySched.active   = false;
              autoTimerRunning    = false;
              setRelay(false);
            }
            waitForPirLow = false; // clear blocker
            saveState("combined-config");

            char modeBuf[12];
            modeName(deviceMode, modeBuf, sizeof(modeBuf));
            snprintf(ackBuf, sizeof(ackBuf),
                     "ACK: Config Saved. Mode=%s | Auto=%dmin | Daily=%02d:%02d-%02d:%02d",
                     modeBuf, autoMins,
                     dailySched.startHour, dailySched.startMin,
                     dailySched.endHour,   dailySched.endMin);
            tcpSend(ackBuf);
            tcpSend("REQUEST:SYNC_STATE");
            isAuthenticated = false;
            tcpSend("ACK: Re-authentication required - send the token now.");
          }
        }
        continue;
      }

      // 2. TOKEN CHANGE:<new_token>
      if (strncmp(upperBuf, "TOKEN CHANGE:", 13) == 0) {
        char* newTok = trimmedLine + 13;
        while (*newTok == ' ') newTok++;
        if (strlen(newTok) == 0) {
          tcpSend("ERR: Use format TOKEN CHANGE:<new_token>");
        } else if (strcmp(newTok, activeToken) == 0) {
          tcpSend("ERR: New token matches current token.");
        } else if (strlen(newTok) >= sizeof(activeToken)) {
          tcpSend("ERR: New token too long.");
        } else {
          saveToken(newTok);
          isAuthenticated = false;
          tcpSend("ACK: Token updated and saved to Flash. Re-authentication required - send the NEW token now.");
        }
        continue;
      }

      // 3. AUTO CHANGE:<minutes>
      if (strncmp(upperBuf, "AUTO CHANGE:", 12) == 0) {
        int mins = atoi(trimmedLine + 12);
        if (mins <= 0) {
          tcpSend("ERR: AUTO CHANGE:<minutes> must be > 0");
        } else {
          autoTimerDuration = (unsigned long)mins * 60000UL;
          saveState("auto-duration-change");
          snprintf(ackBuf, sizeof(ackBuf),
                   "ACK: AUTO duration updated to %dmin in flash. Mode unchanged.", mins);
          tcpSend(ackBuf);
          isAuthenticated = false;
          tcpSend("ACK: Re-authentication required - send the token now.");
        }
        continue;
      }

      // 4. DAILY CHANGE:HH:MM,HH:MM
      if (strncmp(upperBuf, "DAILY CHANGE:", 13) == 0) {
        DailySchedule ns = {0, 0, 0, 0, false, false, 0};
        if (!parseDailyCommand(trimmedLine, ns)) {
          tcpSend("ERR: Format: DAILY CHANGE:HH:MM,HH:MM");
        } else if (ns.startHour * 60 + ns.startMin == ns.endHour * 60 + ns.endMin) {
          tcpSend("ERR: Start and End times must differ.");
        } else {
          dailySched.startHour  = ns.startHour;
          dailySched.startMin   = ns.startMin;
          dailySched.endHour    = ns.endHour;
          dailySched.endMin     = ns.endMin;
          dailySched.configured = true;
          saveState("daily-time-change");
          snprintf(ackBuf, sizeof(ackBuf),
                   "ACK: DAILY times updated to ON=%02d:%02d OFF=%02d:%02d in flash.",
                   dailySched.startHour, dailySched.startMin,
                   dailySched.endHour,   dailySched.endMin);
          tcpSend(ackBuf);
          isAuthenticated = false;
          tcpSend("ACK: Re-authentication required - send the token now.");
        }
        continue;
      }

      // ──────────────────────────────────────────────────────
      //  5-8. INDEPENDENT SUB-TOGGLES 
      // ──────────────────────────────────────────────────────
      // 5. AUTO:ON  
      if (strcmp(upperBuf, "AUTO:ON") == 0) {
        if (autoTimerDuration == 0) {
          tcpSend("ERR: No AUTO timer saved. Use AUTO CHANGE:<mins> first.");
        } else {
          if (deviceMode != 4) deviceMode = 4; 
          waitForPirLow      = false;
          lastPirState       = digitalRead(PIR_PIN);
          lastPirChangeTime  = millis();
          saveState("auto-resume");
          tcpSend("ACK: Motion Sensor ACTIVATED. Daily Schedule remains unchanged.");
          isAuthenticated = false;
          tcpSend("ACK: Re-authentication required - send the token now.");
        }
        continue;
      }

      // 6. AUTO:STOP 
      if (strcmp(upperBuf, "AUTO:STOP") == 0) {
        autoTimerDuration = 0;      
        autoTimerRunning  = false;
        if (!manualOverrideON && dailySched.state != 1) setRelay(false);
        saveState("auto-pause");
        tcpSend("ACK: Motion Sensor DEACTIVATED. Daily Schedule remains active.");
        isAuthenticated = false;
        tcpSend("ACK: Re-authentication required - send the token now.");
        continue;
      }

      // 7. DAILY:ON 
      if (strcmp(upperBuf, "DAILY:ON") == 0) {
        if (!dailySched.configured) {
          tcpSend("ERR: No DAILY schedule saved. Set one first.");
        } else {
          if (deviceMode != 4) deviceMode = 4;
          dailySched.active = true;
          dailySched.state  = 0; 
          saveState("daily-resume");
          tcpSend("ACK: Daily Clock ACTIVATED. Motion Sensor remains unchanged.");
          isAuthenticated = false;
          tcpSend("ACK: Re-authentication required - send the token now.");
        }
        continue;
      }

      // 8. DAILY:STOP 
      if (strcmp(upperBuf, "DAILY:STOP") == 0) {
        dailySched.active = false;
        dailySched.state  = 0;
        if (!autoTimerRunning && !manualOverrideON) setRelay(false);
        saveState("daily-pause");
        tcpSend("ACK: Daily Clock DEACTIVATED. Motion Sensor remains active.");
        isAuthenticated = false;
        tcpSend("ACK: Re-authentication required - send the token now.");
        continue;
      }

      // ──────────────────────────────────────────────────────
      //  RAM COMMANDS (VOLATILE — no flash writes)
      // ──────────────────────────────────────────────────────
      if (strcmp(upperBuf, "STOP") == 0) {
        changeMode(0);
        schedule.active   = false;
        dailySched.active = false;
        autoTimerRunning  = false;
        manualOverrideON  = false;
        setRelay(false);
        tcpSend("ACK: All timers STOPPED. Relay OFF (Manual, Volatile)");
        continue;
      }

      // ──────────────────────────────────────────────────────
      //  TRUE LATCHING MANUAL COMMANDS (RAM only, volatile)
      // ──────────────────────────────────────────────────────
      if (strcmp(upperBuf, "OFF") == 0) {
        manualOverrideON = false; 
        if (deviceMode == 4) {
          if (dailySched.state == 1) {
            dailySched.state = 2; // skip until tomorrow
            autoTimerRunning = false;
            setRelay(false);
            waitForPirLow = true;
            tcpSend("ACK: Daily schedule skipped. Relay OFF. (Waiting for tomorrow)");
          } else if (autoTimerRunning) {
            autoTimerRunning = false;
            setRelay(false);
            waitForPirLow = true;
            tcpSend("ACK: Motion timer stopped early. Relay OFF. (Waiting for NEW motion)");
          } else {
            setRelay(false);
            tcpSend("ACK: Manual Override cleared. Relay OFF. (Automation is active)");
          }
        } else if (deviceMode == 2) {
          if (autoTimerRunning) {
            autoTimerRunning = false;
            setRelay(false);
            waitForPirLow = true;
            tcpSend("ACK: Motion timer stopped early. Relay OFF.");
          } else {
            setRelay(false);
            tcpSend("ACK: Manual Override cleared. Relay OFF.");
          }
        } else {
          changeMode(0);
          setRelay(false);
          tcpSend("ACK: Relay OFF (Manual Mode)");
        }
        continue;
      }

      if (strcmp(upperBuf, "ON") == 0) {
        if (deviceMode == 4) {
          if (dailySched.state == 1) {
            tcpSend("ERR: Daily Schedule is actively running. ON command ignored.");
          } else if (autoTimerRunning) {
            tcpSend("ERR: Auto motion timer is actively running. ON command ignored.");
          } else {
            manualOverrideON = true;
            autoTimerRunning = false;
            setRelay(true);
            tcpSend("ACK: Manual ON accepted. Relay will stay ON until you send the OFF command.");
          }
        } else if (deviceMode == 2) {
          if (autoTimerRunning) {
            tcpSend("ERR: Auto motion timer is actively running. ON command ignored.");
          } else {
            manualOverrideON = true;
            autoTimerRunning = false;
            setRelay(true);
            tcpSend("ACK: Manual ON accepted. Relay will stay ON until you send the OFF command.");
          }
        } else {
          changeMode(0);
          setRelay(true);
          tcpSend("ACK: Relay ON (Manual Mode)");
        }
        continue;
      }

      if (strncmp(upperBuf, "CUSTOM:", 7) == 0) {
        CustomSchedule ns;
        if (parseCustomCommand(trimmedLine, ns)) {
          time_t nowT = time(nullptr);
          struct tm* t = localtime(&nowT);
          if (t->tm_year + 1900 < 2024) {
            tcpSend("ERR: NTP not synced yet. Wait 10s and retry.");
            continue;
          }
          bool pastDate = (ns.year < t->tm_year + 1900)
            || (ns.year == t->tm_year + 1900 && ns.month < t->tm_mon + 1)
            || (ns.year == t->tm_year + 1900 && ns.month == t->tm_mon + 1
                && ns.day < t->tm_mday);
          if (pastDate) {
            tcpSend("ERR: Date is in the past.");
            continue;
          }
          bool today = (ns.year  == t->tm_year + 1900
                        && ns.month == t->tm_mon  + 1
                        && ns.day   == t->tm_mday);
          if (today) {
            int nowM  = t->tm_hour * 60 + t->tm_min;
            int startM = ns.startHour * 60 + ns.startMin;
            if (startM <= nowM) {
              tcpSend("ERR: Start time already passed.");
              continue;
            }
          }
          if (ns.startHour * 60 + ns.startMin == ns.endHour * 60 + ns.endMin) {
            tcpSend("ERR: Start and End times must differ.");
            continue;
          }
          changeMode(3);
          dailySched.active = false;
          autoTimerRunning  = false;
          schedule          = ns;
          setRelay(false);
          snprintf(ackBuf, sizeof(ackBuf),
                   "ACK: Volatile Schedule Activated. ON at %02d:%02d, OFF at %02d:%02d",
                   schedule.startHour, schedule.startMin,
                   schedule.endHour,   schedule.endMin);
          tcpSend(ackBuf);
        } else {
          tcpSend("ERR: Format: CUSTOM:DD/MM/YYYY;HH:MM;HH:MM");
        }
        continue;
      }

      // ──────────────────────────────────────────────────────
      //  SYSTEM & DIAGNOSTIC COMMANDS
      // ──────────────────────────────────────────────────────
      
      if (strcmp(upperBuf, "RESET") == 0) {
        pendingReset = true;
        tcpSend("REQUEST: Warning! This will erase all Wi-Fi and Security data. Send your token now to confirm.");
        continue;
      }

      if (strcmp(upperBuf, "FLASH STATUS") == 0) {
        uint32_t percent = (uint32_t)((flashWriteCount * 100UL) / 90000UL);
        snprintf(ackBuf, sizeof(ackBuf),
                 "STATUS: Flash Memory=(%lu/90k) | Wear=%lu%% | Health=%s",
                 flashWriteCount, (unsigned long)percent,
                 (percent < 50 ? "GOOD" : (percent < 90 ? "WARNING" : "CRITICAL")));
        tcpSend(ackBuf);
        continue;
      }

      if (strcmp(upperBuf, "FLASH LIST") == 0) {
        tcpSend("FLASH COMMANDS (writes to flash / persist across reboot):");
        tcpSend("  RESET                           -> 2-Step FULL WIPE of WiFi and Registration");
        tcpSend("  <token>                         -> first-time correct token = auto REGISTER + SAVE");
        tcpSend("  AUTO:<mins>|DAILY:HH:MM,HH:MM   -> combined config save (sets mode)");
        tcpSend("  AUTO CHANGE:<mins>              -> update AUTO duration only");
        tcpSend("  AUTO:ON                         -> resume motion sensor (Mode 4 sub-toggle)");
        tcpSend("  AUTO:STOP                       -> pause motion sensor, DAILY unaffected");
        tcpSend("  DAILY CHANGE:HH:MM,HH:MM        -> update DAILY times only");
        tcpSend("  DAILY:ON                        -> resume daily clock (Mode 4 sub-toggle)");
        tcpSend("  DAILY:STOP                      -> pause daily clock, AUTO unaffected");
        tcpSend("  TOKEN CHANGE:<new_token>        -> replace token (forces re-auth)");
        tcpSend("NON-FLASH (RAM only, volatile): ON, OFF, STOP, CUSTOM:DD/MM/YYYY;HH:MM;HH:MM");
        tcpSend("DIAGNOSTIC (no write):          STATUS, FLASH STATUS, FLASH LIST");
        tcpSend("OTA UPDATE COMMAND:             [MAC_ADDRESS]:UPDATE (e.g., 84CCA8123456:UPDATE)");
        continue;
      }

      if (strcmp(upperBuf, "STATUS") == 0) {
        bool relayOn = (digitalRead(RELAY_PIN) == LOW);

        const char* driver = "NONE";
        if (manualOverrideON)                                                  driver = "MANUAL";
        else if (deviceMode == 4 && dailySched.state == 1)                     driver = "DAILY";
        else if ((deviceMode == 2 || deviceMode == 4) && autoTimerRunning)     driver = "AUTO";
        else if (deviceMode == 3 && schedule.active && schedule.hasTriggeredOn)driver = "CUSTOM";
        else if (relayOn)                                                      driver = "MANUAL"; // ON in Mode 0

        snprintf(ackBuf, sizeof(ackBuf),
                 "STATUS: DAILY:%s   LOAD:%s",
                 (dailySched.active ? "active" : "inactive"),
                 (deviceMode == 4 && dailySched.state == 1) ? "ON" : "OFF");
        tcpSend(ackBuf);

        snprintf(ackBuf, sizeof(ackBuf),
                 "STATUS: AUTO:%s   LOAD:%s",
                 (autoTimerDuration > 0 ? "active" : "inactive"),
                 ((deviceMode == 2 || deviceMode == 4) && autoTimerRunning) ? "ON" : "OFF");
        tcpSend(ackBuf);

        snprintf(ackBuf, sizeof(ackBuf), "STATUS: DRIVER:%s   RELAY:%s", driver, relayOn ? "ON" : "OFF");
        tcpSend(ackBuf);

        uint32_t percent = (uint32_t)((flashWriteCount * 100UL) / 90000UL);
        snprintf(ackBuf, sizeof(ackBuf), "STATUS: FLASH:%lu/90000 (%lu%%)",
                 flashWriteCount, (unsigned long)percent);
        tcpSend(ackBuf);

        // SMART FIRMWARE VERSION PRINT
        snprintf(ackBuf, sizeof(ackBuf), "STATUS: FIRMWARE VERSION: v%s", CURRENT_VERSION);
        tcpSend(ackBuf);
        continue;
      }

      tcpSend("ERR: Unknown command");
      if (!isDeviceConfigured()) {
        tcpSend("REMINDER: Device not yet configured. Send -> auto:<mins>|daily:HH:MM,HH:MM");
      }
    }
    else if (c != '\r') {
      if (bufIdx < LINE_BUF_SZ - 1) {
        lineBuf[bufIdx++] = c;
      }
    }
  }

  // ── SILENT HEARTBEAT ──
  run_modes:

  if (isAuthenticated && millis() - lastHeartbeatTime > HEARTBEAT_MS) {
    lastHeartbeatTime = millis();
    if (!tcpSend(" ")) {
      Serial.println(F("Heartbeat: dead connection — reconnecting."));
    }
  }

  // ============================================================
  //  SECTION 4 — MODE EXECUTION
  // ============================================================

  // ── MODE 2 & 4: AUTO_TIMED & DAILY HYBRID ──
  if (deviceMode == 2 || (deviceMode == 4 && dailySched.active)) {

    bool inDailyWindow = false;

    if (deviceMode == 4) {
      time_t nowT = time(nullptr);
      struct tm* t = localtime(&nowT);
      if (t->tm_year + 1900 >= 2024) {
        int nowMins   = t->tm_hour * 60 + t->tm_min;
        int startMins = dailySched.startHour * 60 + dailySched.startMin;
        int endMins   = dailySched.endHour   * 60 + dailySched.endMin;

        if (startMins < endMins) {
          inDailyWindow = (nowMins >= startMins && nowMins < endMins);
        } else {
          inDailyWindow = (nowMins >= startMins || nowMins < endMins);
        }
      }
    }

    if (deviceMode == 4) {
      if (inDailyWindow) {
        if (dailySched.state == 0) {
          dailySched.state = 1;
          autoTimerRunning = false;
          setRelay(true);
          if (isAuthenticated) tcpSend("EVENT: Daily schedule active - Relay ON (PIR suspended)");
        }
      } else {
        if (dailySched.state == 1) {
          dailySched.state = 0;
          if (!autoTimerRunning && !manualOverrideON) setRelay(false);
          if (isAuthenticated) tcpSend("EVENT: Daily schedule finished - Relay OFF (PIR resumed)");
        } else if (dailySched.state == 2) {
          dailySched.state = 0;
          if (!autoTimerRunning && !manualOverrideON) setRelay(false);
          if (isAuthenticated) tcpSend("EVENT: Skip-today period ended - DAILY resumed for next window.");
        }
      }
    }

    bool runPirLogic = false;
    if (deviceMode == 2) {
      runPirLogic = true;
    } else if (deviceMode == 4 && autoTimerDuration > 0) {
      runPirLogic = (dailySched.state != 1);
    }

    if (runPirLogic) {
      // 1. HARDWARE WARM-UP BLOCK
      if (millis() < 30000UL) {
        lastPirState = LOW;
        lastPirChangeTime = millis(); 
      } else {
        bool pir = digitalRead(PIR_PIN);

        // 2. TRUE EDGE-TRIGGERED DEBOUNCE (EMI PROTECTION)
        if (pir != lastPirState) {
          if (millis() - lastPirChangeTime > DEBOUNCE_MS) {
            
            lastPirState = pir;
            lastPirChangeTime = millis();

            if (pir == LOW) {
              waitForPirLow = false; 
            }

            // 3. TRIGGER ONLY ON RISING EDGE
            if (pir == HIGH && !autoTimerRunning && !autoInCooldown && !waitForPirLow && !manualOverrideON) {
              setRelay(true);
              autoTimerRunning   = true;
              autoTimerStartTime = millis();

              if (isAuthenticated) {
                char buf[64];
                snprintf(buf, sizeof(buf),
                         "EVENT: Motion Detected - Relay ON for %lus",
                         autoTimerDuration / 1000UL);
                tcpSend(buf);
              }
            }
          }
        } else {
          lastPirChangeTime = millis();
        }
      }

      // 4. COOLDOWN HANDLER
      if (autoInCooldown) {
        if (millis() - autoCooldownStart >= AUTO_COOLDOWN_MS) {
          autoInCooldown = false;
        }
      }

      // 5. TIMER EXPIRATION
      if (autoTimerRunning && millis() - autoTimerStartTime >= autoTimerDuration) {
        autoTimerRunning = false;
        setRelay(false);
        autoInCooldown    = true;
        autoCooldownStart = millis();
        if (isAuthenticated) tcpSend("EVENT: Timer expired - Relay OFF");
      }
    }
  }

  // ── MODE 3: CUSTOM ──
  else if (deviceMode == 3 && schedule.active) {
    time_t nowT = time(nullptr);
    struct tm* t = localtime(&nowT);
    if (t->tm_year + 1900 < 2024) return;

    bool isToday = (schedule.year  == t->tm_year + 1900
                    && schedule.month == t->tm_mon  + 1
                    && schedule.day   == t->tm_mday);
    if (!isToday) return;

    int nowMins   = t->tm_hour * 60 + t->tm_min;
    int startMins = schedule.startHour * 60 + schedule.startMin;
    int endMins   = schedule.endHour   * 60 + schedule.endMin;
    bool inWindow = (nowMins >= startMins && nowMins < endMins);

    if (inWindow) {
      if (!schedule.hasTriggeredOn) {
        schedule.hasTriggeredOn = true;
        setRelay(true);
        if (isAuthenticated) tcpSend("EVENT: Schedule started - Relay ON");
      }
    } else if (schedule.hasTriggeredOn) {
      setRelay(false);
      schedule.active = false;
      if (isAuthenticated) tcpSend("EVENT: Schedule finished - Relay OFF");
      changeMode(0);
    }
  }
}
